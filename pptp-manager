#!/bin/bash
VERSION="1.0.0"

setup_vpn() {
    read -p "Profile Name [officevpn]: " PROFILE
    PROFILE=${PROFILE:-officevpn}

    read -p "VPN Server IP or Hostname: " SERVER
    read -p "VPN Username: " USERNAME
    read -s -p "VPN Password: " PASSWORD
    echo

    mkdir -p /etc/ppp/peers

    cat > "/etc/ppp/peers/$PROFILE" <<EOF
pty "pptp $SERVER --nolaunchpptp"
name "$USERNAME"
remotename $PROFILE
require-mppe-128
require-mschap-v2
refuse-eap
refuse-pap
refuse-chap
refuse-mschap
persist
maxfail 0
holdoff 10
defaultroute
replacedefaultroute
usepeerdns
EOF

    grep -v " $PROFILE " /etc/ppp/chap-secrets 2>/dev/null > /tmp/chap-secrets.tmp || true
    mv /tmp/chap-secrets.tmp /etc/ppp/chap-secrets

    echo "$USERNAME $PROFILE \"$PASSWORD\" *" >> /etc/ppp/chap-secrets
    chmod 600 /etc/ppp/chap-secrets

    echo ""
    echo "VPN profile '$PROFILE' created successfully."
}
start_vpn() {
    PROFILE="$1"

    if [ -z "$PROFILE" ]; then
        echo "Usage: pptp-manager start <profile>"
        exit 1
    fi

    echo "Starting VPN profile: $PROFILE"

    pon "$PROFILE"

    sleep 5

    if ip link show | grep -q ppp; then
        echo "VPN connected successfully."
    else
        echo "Connection failed."
        journalctl -n 30 | grep -Ei "ppp|pptp"
    fi
}
stop_vpn() {
    PROFILE="$1"

    if [ -z "$PROFILE" ]; then
        poff -a
    else
        poff "$PROFILE"
    fi

    echo "VPN disconnected."
}
restart_vpn() { poff "$1" || true; sleep 2; pon "$1"; }
status_vpn() {
    PPP_IF=$(ip -o link show | awk -F': ' '/ppp/{print $2}' | head -1)

    if [ -n "$PPP_IF" ]; then
        echo "Status     : CONNECTED"
        echo "Interface  : $PPP_IF"

        ip -4 addr show "$PPP_IF" | grep inet

        echo ""
        echo "Routes:"
        ip route | grep "$PPP_IF"

        echo ""
        echo -n "Public IP  : "
        curl -s --max-time 5 ifconfig.me
        echo
    else
        echo "Disconnected"
    fi
}
logs_vpn() { journalctl -xe | grep -Ei "ppp|pptp" | tail -50; }

menu() {
while true; do
    echo ""
    echo "========== PPTP Manager =========="
    echo "1) Setup VPN"
    echo "2) Start VPN"
    echo "3) Stop VPN"
    echo "4) Restart VPN"
    echo "5) Status"
    echo "6) Logs"
    echo "7) Exit"
    echo ""

    read -p "Select option: " CHOICE

    case $CHOICE in
        1) setup_vpn ;;
        2) read -p "Profile: " P; start_vpn "$P" ;;
        3) read -p "Profile: " P; stop_vpn "$P" ;;
        4) read -p "Profile: " P; restart_vpn "$P" ;;
        5) status_vpn ;;
        6) logs_vpn ;;
        7) exit 0 ;;
    esac
done
}

case "$1" in
 setup) setup_vpn ;;
 start) start_vpn "$2" ;;
 stop) stop_vpn "$2" ;;
 restart) restart_vpn "$2" ;;
 status) status_vpn ;;
 logs) logs_vpn ;;
 *)
    menu
    ;;
esac
